# ChartForge Configuration
# Default output directory for saved charts
CHARTFORGE_OUTPUT_DIR=./output

# Default chart dimensions
CHARTFORGE_WIDTH=800
CHARTFORGE_HEIGHT=600

# Default color palette (comma-separated hex values)
CHARTFORGE_PALETTE=#4E79A7,#F28E2B,#E15759,#76B7B2,#59A14F,#EDC948,#B07AA1,#FF9DA7
